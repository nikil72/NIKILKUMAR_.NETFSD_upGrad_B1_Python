@{ ViewData["Title"] = "Create Account"; }

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon-wrap">
                <svg width="32" height="32" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="8" fill="#6C63FF"/><path d="M7 14L11 10L15 16L19 12L21 14" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h1>Create account</h1>
            <p>Start learning for free today</p>
        </div>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-error">⚠ @ViewBag.Error</div>
        }
        <form method="post" asp-action="Register" class="auth-form">
            <div class="form-group">
                <label>Full name</label>
                <input type="text" name="fullName" placeholder="John Doe" required autocomplete="name" />
            </div>
            <div class="form-group">
                <label>Email address</label>
                <input type="email" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
            <div class="form-group">
                <label>Password <span class="label-hint">(min 6 characters)</span></label>
                <input type="password" name="password" placeholder="••••••••" required minlength="6" autocomplete="new-password" />
            </div>
            <button type="submit" class="btn-submit">Create Account</button>
        </form>
        <p class="auth-switch">Already have an account? <a asp-action="Login">Sign in</a></p>
    </div>
</div>
